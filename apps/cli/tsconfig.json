{
	"extends": "@sindresorhus/tsconfig",
	"compilerOptions": {
		"outDir": "dist",
		"module": "esnext",
		"moduleResolution": "bundler",
		"types": ["node", "react"]
	},
	"ts-node": {
		"experimentalSpecifierResolution": "node",
		"compilerOptions": {
			"module": "esnext",
			"moduleResolution": "bundler"
		}
	},
	"include": ["source", "test.tsx"]
}
