{
  "name": "@ztools/core",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist"],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "check-types": "tsgo --noEmit",
    "test": "ava"
  },
  "devDependencies": {
    "@typescript/native-preview": "latest",
    "ava": "^5.2.0",
    "ts-node": "^10.9.1",
    "tsdown": "^0.9.0",
    "typescript": "5.9.2"
  },
  "ava": {
    "extensions": {"ts": "module"},
    "nodeArguments": ["--loader=ts-node/esm"]
  }
}
